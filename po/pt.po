#: data/io.github.revisto.drum-machine.metainfo.xml.in:6 src/application.py:67 src/window.ui:69
msgid "Drum Machine"
msgstr "Drum Machine"

#. Translators: Search terms to find this application. Do NOT translate or localise the semicolons! The list MUST also end with a semicolon!
#: data/io.github.revisto.drum-machine.desktop.in:9
msgid "drum;drums;sequencer;rhythm;music;pattern;beats;percussion;loop;groove;"
msgstr "drum;drums;sequenciador;ritmo;música;padrão;batidas;percussão;loop;groove;bateria;ritmos;"

#: data/io.github.revisto.drum-machine.metainfo.xml.in:7
msgid "Create and play drum beats"
msgstr "Crie e reproduza batidas de bateria"

#: data/io.github.revisto.drum-machine.metainfo.xml.in:9
msgid ""
"Drum Machine is a modern and intuitive application for creating, playing, and managing drum "
"patterns. Perfect for musicians, producers, and anyone interested in rhythm creation, this "
"application provides a simple interface for drum pattern programming. Have fun!"
msgstr ""
"A Drum Machine é uma aplicação moderna e intuitiva para criar, reproduzir e gerir padrões de "
"bateria. Perfeita para músicos, produtores e qualquer pessoa interessada na criação de ritmos, "
"esta aplicação oferece uma interface simples para a programação de padrões de bateria. Divirta-"
"se!"

#: data/io.github.revisto.drum-machine.metainfo.xml.in:15
msgid "Features:"
msgstr "Funcionalidades:"

#: data/io.github.revisto.drum-machine.metainfo.xml.in:17
msgid "Intuitive grid-based pattern editor with infinite pages"
msgstr "Editor de padrões intuitivo baseado em grelha com páginas infinitas"

#: data/io.github.revisto.drum-machine.metainfo.xml.in:18
msgid "Custom samples: Add your own drum sounds with MIDI note mapping"
msgstr "Amostras personalizadas: adicione os seus sons de bateria com mapeamento de notas MIDI"

#: data/io.github.revisto.drum-machine.metainfo.xml.in:19
msgid "Adjustable BPM control"
msgstr "Controlo de BPM ajustável"

#: data/io.github.revisto.drum-machine.metainfo.xml.in:20
msgid "Volume control for overall mix"
msgstr "Controlo de volume para a mistura geral"

#: data/io.github.revisto.drum-machine.metainfo.xml.in:21
msgid "Save and load patterns"
msgstr "Guardar e carregar padrões"

#: data/io.github.revisto.drum-machine.metainfo.xml.in:22
msgid "Multiple drum sounds including kick, snare, hi-hat, and more"
msgstr "Vários sons de bateria incluindo bombo, tarola, pratos e muito mais"

#: data/io.github.revisto.drum-machine.metainfo.xml.in:23
msgid "Audio and MIDI export with support for WAV, FLAC, Ogg, MP3, and MIDI formats"
msgstr "Exportação de áudio e MIDI com suporte para os formatos WAV, FLAC, Ogg, MP3 e MIDI"

#: data/io.github.revisto.drum-machine.metainfo.xml.in:24
msgid "Metadata support for embedding artist name, song title, and cover art"
msgstr "Suporte para metadados para incluir nome do artista, título da música e capa"

#: data/io.github.revisto.drum-machine.metainfo.xml.in:25
msgid "Keyboard shortcuts for quick access to all functions"
msgstr "Atalhos de teclado para acesso rápido a todas as funções"

#: data/io.github.revisto.drum-machine.metainfo.xml.in:34
msgid "Drum Pattern Loaded in Light Mode"
msgstr "Padrão de Bateria Carregado em Modo Claro"

#: data/io.github.revisto.drum-machine.metainfo.xml.in:38
msgid "Drum Pattern Loaded in Dark Mode"
msgstr "Padrão de Bateria Carregado em Modo Escuro"

